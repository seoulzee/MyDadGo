<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>아버님 전용 AI 기원</title>
    <script src="https://cdn.jsdelivr.net/npm/wgo@2.3.1/wgo.min.js"></script>
    <style>
        body { text-align: center; background: #e9ecef; font-family: '맑은 고딕', sans-serif; }
        h1 { color: #2c3e50; margin-top: 30px; }
        p { color: #555; }
        
        /* 바둑판 박스 */
        #board-container {
            width: 500px;
            height: 500px;
            margin: 20px auto;
            background-color: #e4a054; /* 💡 예쁜 살구빛 나무색을 칠합니다 */
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
            border: 2px solid #333;
        }
    </style>
</head>
<body>

    <h1>아버님 전용 AI 기원 🎴</h1>
    <p>마우스로 바둑판을 클릭해서 돌을 놓아보세요!</p>
    
    <div id="board-container"></div>

    <script>
        // 1픽셀 투명 이미지 (바둑판 로딩 지연 방지용 마법 꼼수)
        var fakeImage = "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNkYAAAAAYAAjCB0C8AAAAASUVORK5CYII=";
        
        // 1️⃣ 바둑판 엔진 가동! (깃허브에서는 절대 안 막힙니다)
        var board = new WGo.Board(document.getElementById("board-container"), {
            width: 500,
            size: 19,
            background: fakeImage
        });

        // 2️⃣ 바둑 심판 부르기
        var game = new WGo.Game(19);

        // 3️⃣ 클릭하면 진짜로 돌이 놓이게 만들기!
        board.addEventListener("click", function(x, y) {
            var result = game.play(x, y);

            if (typeof result == "number") {
                // 반칙이 아니면 돌을 착! 하고 놓습니다
                board.update(game.getPosition());
            } else {
                alert("아버님, 거기는 돌을 놓을 수 없는 자리(반칙)입니다!");
            }
        });
    </script>
</body>
</html>
